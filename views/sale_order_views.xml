<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
    =============================================================================
    hak_call_center - sale_order_views.xml
    Author:  Hadi Katranji
    Created: 2026-03-24

    Adds Call Center Agent (related from customer) to sale order list and form.
    =============================================================================
    -->

    <!-- Add CC agent to sale order list view -->
    <record id="view_sale_order_tree_inherit_call_center" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.hak_call_center</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <field name="user_id" position="after">
                <field name="hak_call_center_id" optional="show"/>
            </field>
        </field>
    </record>

    <!-- Add CC agent to sale order form view -->
    <record id="view_sale_order_form_inherit_call_center" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.hak_call_center</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <field name="user_id" position="after">
                <field name="hak_call_center_id"/>
            </field>
        </field>
    </record>

</odoo>
