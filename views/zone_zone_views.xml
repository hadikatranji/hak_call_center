<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
    =============================================================================
    hak_call_center - zone_zone_views.xml
    Author:  Hadi Katranji
    Created: 2026-03-24

    Adds "Call Center" tab to the zone form view (notebook).
    Inherits the existing zone.zone form from das_zone_location.
    =============================================================================
    -->

    <!-- Add Call Center tab to zone form notebook -->
    <record id="view_zone_zone_form_inherit_call_center" model="ir.ui.view">
        <field name="name">zone.zone.form.inherit.hak_call_center</field>
        <field name="model">zone.zone</field>
        <field name="inherit_id" ref="das_zone_location.zone_view_form"/>
        <field name="arch" type="xml">
            <!-- HAK: Add "Call Center" tab inside the notebook,
                 after existing tabs (Areas, Route, Geolocation, Surveyors, Retailer, Drivers) -->
            <xpath expr="//notebook" position="inside">
                <page string="Team" name="call_center">
                    <group>
                        <field name="champion_id"
                               string="Champion (Salesperson)"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="call_center_id"
                               string="Call Center Agent"
                               options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
